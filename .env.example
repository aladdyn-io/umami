# Umami — environment variables
# Copy this to .env for local development.
# For Railway: set these in the Railway dashboard (Variables tab).

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Railway internal: postgresql://postgres:<password>@postgres.railway.internal:5432/railway
# Local Docker:     postgresql://aladdyn:aladdyn_dev@localhost:5433/umami_db
DATABASE_URL=

# Secret used to sign JWT session tokens. Must be a random string.
# Generate one: openssl rand -base64 32
SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────

# Port the server listens on. Railway sets this automatically; no need to override.
PORT=3000

# Hostname. Default is 0.0.0.0 (all interfaces), which is correct for containers.
HOSTNAME=0.0.0.0

# Default locale for the UI (e.g. en, fr, de). Defaults to en.
# DEFAULT_LOCALE=en

# Disable Umami's own telemetry ping to umami.is.
NEXT_TELEMETRY_DISABLED=1

# Base path if running behind a sub-path proxy (e.g. /analytics). Leave blank otherwise.
# BASE_PATH=

# Log SQL queries to stdout (debug only).
# LOG_QUERY=1

# Read-replica URL for query load balancing.
# DATABASE_REPLICA_URL=
